{"words": [{"id": 1, "w": "apple", "k": "アップル", "p": "名詞", "m": ["りんご"], "ex": "I eat an apple every day.", "level": 1, "exj": "私は毎日りんごを食べます。"}, {"id": 2, "w": "bag", "k": "バッグ", "p": "名詞", "m": ["かばん", "バッグ"], "ex": "She has a red bag.", "level": 1, "exj": "彼女は赤いかばんを持っています。"}, {"id": 3, "w": "book", "k": "ブック", "p": "名詞", "m": ["本"], "ex": "I read a book every night.", "level": 1, "exj": "私は毎晩本を読みます。"}, {"id": 4, "w": "cat", "k": "キャット", "p": "名詞", "m": ["ねこ"], "ex": "The cat is sleeping on the sofa.", "level": 1, "exj": "猫はソファの上で寝ています。"}, {"id": 5, "w": "dog", "k": "ドッグ", "p": "名詞", "m": ["いぬ"], "ex": "My dog is very friendly.", "level": 1, "exj": "私の犬はとても人なつっこいです。"}, {"id": 6, "w": "egg", "k": "エッグ", "p": "名詞", "m": ["たまご"], "ex": "I had an egg for breakfast.", "level": 1, "exj": "私は朝食に卵を食べました。"}, {"id": 7, "w": "fish", "k": "フィッシュ", "p": "名詞", "m": ["さかな"], "ex": "We caught a big fish.", "level": 1, "exj": "私たちは大きな魚を釣りました。"}, {"id": 8, "w": "girl", "k": "ガール", "p": "名詞", "m": ["女の子"], "ex": "The girl is my sister.", "level": 1, "exj": "その女の子は私の妹です。"}, {"id": 9, "w": "house", "k": "ハウス", "p": "名詞", "m": ["家"], "ex": "We live in a big house.", "level": 1, "exj": "私たちは大きな家に住んでいます。"}, {"id": 10, "w": "ice", "k": "アイス", "p": "名詞", "m": ["氷"], "ex": "Please put some ice in my drink.", "level": 1, "exj": "私の飲み物に氷を入れてください。"}, {"id": 11, "w": "juice", "k": "ジュース", "p": "名詞", "m": ["ジュース"], "ex": "I drink orange juice every morning.", "level": 1, "exj": "私は毎朝オレンジジュースを飲みます。"}, {"id": 12, "w": "key", "k": "キー", "p": "名詞", "m": ["かぎ"], "ex": "I can't find my key.", "level": 1, "exj": "鍵が見つかりません。"}, {"id": 13, "w": "lunch", "k": "ランチ", "p": "名詞", "m": ["昼食"], "ex": "Let's have lunch together.", "level": 1, "exj": "一緒にランチを食べましょう。"}, {"id": 14, "w": "milk", "k": "ミルク", "p": "名詞", "m": ["ぎゅうにゅう", "ミルク"], "ex": "I drink a glass of milk every day.", "level": 1, "exj": "私は毎日牛乳を一杯飲みます。"}, {"id": 15, "w": "name", "k": "ネーム", "p": "名詞", "m": ["なまえ"], "ex": "What is your name?", "level": 1, "exj": "あなたの名前は何ですか？"}, {"id": 16, "w": "orange", "k": "オレンジ", "p": "名詞", "m": ["オレンジ"], "ex": "An orange is sweet and juicy.", "level": 1, "exj": "オレンジは甘くてジューシーです。"}, {"id": 17, "w": "pen", "k": "ペン", "p": "名詞", "m": ["ペン"], "ex": "Can I borrow your pen?", "level": 1, "exj": "ペンを借りてもいいですか？"}, {"id": 18, "w": "queen", "k": "クイーン", "p": "名詞", "m": ["女王"], "ex": "The queen lives in the palace.", "level": 1, "exj": "女王は宮殿に住んでいます。"}, {"id": 19, "w": "rain", "k": "レイン", "p": "名詞", "m": ["雨"], "ex": "It looks like rain today.", "level": 1, "exj": "今日は雨が降りそうです。"}, {"id": 20, "w": "school", "k": "スクール", "p": "名詞", "m": ["学校"], "ex": "I go to school by bus.", "level": 1, "exj": "私はバスで学校へ行きます。"}, {"id": 21, "w": "table", "k": "テーブル", "p": "名詞", "m": ["テーブル", "食卓"], "ex": "Please sit at the table.", "level": 1, "exj": "テーブルに座ってください。"}, {"id": 22, "w": "uncle", "k": "アンクル", "p": "名詞", "m": ["おじさん"], "ex": "My uncle lives in Tokyo.", "level": 1, "exj": "私のおじは東京に住んでいます。"}, {"id": 23, "w": "water", "k": "ウォーター", "p": "名詞", "m": ["みず"], "ex": "Please give me a glass of water.", "level": 1, "exj": "水を一杯ください。"}, {"id": 24, "w": "year", "k": "イヤー", "p": "名詞", "m": ["年", "〜年"], "ex": "I am twelve years old.", "level": 1, "exj": "私は12歳です。"}, {"id": 25, "w": "zoo", "k": "ズー", "p": "名詞", "m": ["どうぶつえん"], "ex": "We went to the zoo last Sunday.", "level": 1, "exj": "私たちは先週の日曜日に動物園へ行きました。"}, {"id": 26, "w": "ball", "k": "ボール", "p": "名詞", "m": ["ボール", "たま"], "ex": "Kick the ball into the goal.", "level": 1, "exj": "ボールをゴールに蹴り込んでください。"}, {"id": 27, "w": "bird", "k": "バード", "p": "名詞", "m": ["とり"], "ex": "A bird is singing outside.", "level": 1, "exj": "外で鳥が歌っています。"}, {"id": 28, "w": "cake", "k": "ケーキ", "p": "名詞", "m": ["ケーキ"], "ex": "Mom made a chocolate cake.", "level": 1, "exj": "お母さんがチョコレートケーキを作りました。"}, {"id": 29, "w": "door", "k": "ドア", "p": "名詞", "m": ["ドア", "とびら"], "ex": "Please close the door.", "level": 1, "exj": "ドアを閉めてください。"}, {"id": 30, "w": "ear", "k": "イアー", "p": "名詞", "m": ["みみ"], "ex": "I have a pain in my ear.", "level": 1, "exj": "耳が痛いです。"}, {"id": 31, "w": "face", "k": "フェイス", "p": "名詞", "m": ["かお"], "ex": "Wash your face in the morning.", "level": 1, "exj": "朝に顔を洗いましょう。"}, {"id": 32, "w": "game", "k": "ゲーム", "p": "名詞", "m": ["ゲーム", "しあい"], "ex": "Do you like video games?", "level": 1, "exj": "テレビゲームは好きですか？"}, {"id": 33, "w": "hand", "k": "ハンド", "p": "名詞", "m": ["て"], "ex": "Please raise your hand.", "level": 1, "exj": "手を挙げてください。"}, {"id": 34, "w": "idea", "k": "アイデア", "p": "名詞", "m": ["考え", "アイデア"], "ex": "I have a good idea.", "level": 1, "exj": "いい考えがあります。"}, {"id": 35, "w": "leg", "k": "レッグ", "p": "名詞", "m": ["あし（足・脚）"], "ex": "My leg hurts after running.", "level": 1, "exj": "走った後で足が痛いです。"}, {"id": 36, "w": "map", "k": "マップ", "p": "名詞", "m": ["ちず"], "ex": "Let's look at the map.", "level": 1, "exj": "地図を見ましょう。"}, {"id": 37, "w": "news", "k": "ニュース", "p": "名詞", "m": ["ニュース"], "ex": "I watch the news every evening.", "level": 1, "exj": "私は毎晩ニュースを見ます。"}, {"id": 38, "w": "park", "k": "パーク", "p": "名詞", "m": ["こうえん"], "ex": "Children are playing in the park.", "level": 1, "exj": "子どもたちが公園で遊んでいます。"}, {"id": 39, "w": "rice", "k": "ライス", "p": "名詞", "m": ["ごはん", "お米"], "ex": "We eat rice every day.", "level": 1, "exj": "私たちは毎日ご飯を食べます。"}, {"id": 40, "w": "song", "k": "ソング", "p": "名詞", "m": ["うた"], "ex": "She sang a beautiful song.", "level": 1, "exj": "彼女は美しい歌を歌いました。"}, {"id": 41, "w": "tea", "k": "ティー", "p": "名詞", "m": ["おちゃ", "こうちゃ"], "ex": "Would you like some tea?", "level": 1, "exj": "お茶はいかがですか？"}, {"id": 42, "w": "window", "k": "ウィンドウ", "p": "名詞", "m": ["まど"], "ex": "Please open the window.", "level": 1, "exj": "窓を開けてください。"}, {"id": 43, "w": "box", "k": "ボックス", "p": "名詞", "m": ["はこ"], "ex": "Put the books in the box.", "level": 1, "exj": "本を箱に入れてください。"}, {"id": 44, "w": "city", "k": "シティ", "p": "名詞", "m": ["都市", "まち"], "ex": "Tokyo is a big city.", "level": 1, "exj": "東京は大きな都市です。"}, {"id": 45, "w": "desk", "k": "デスク", "p": "名詞", "m": ["つくえ"], "ex": "Please clean your desk.", "level": 1, "exj": "机を片付けてください。"}, {"id": 46, "w": "flower", "k": "フラワー", "p": "名詞", "m": ["はな"], "ex": "I gave her some flowers.", "level": 1, "exj": "私は彼女に花をあげました。"}, {"id": 47, "w": "garden", "k": "ガーデン", "p": "名詞", "m": ["にわ"], "ex": "My mother grows roses in the garden.", "level": 1, "exj": "お母さんは庭でバラを育てています。"}, {"id": 48, "w": "horse", "k": "ホース", "p": "名詞", "m": ["うま"], "ex": "The horse ran very fast.", "level": 1, "exj": "その馬はとても速く走りました。"}, {"id": 49, "w": "island", "k": "アイランド", "p": "名詞", "m": ["しま"], "ex": "The island is very beautiful.", "level": 1, "exj": "その島はとても美しいです。"}, {"id": 50, "w": "kitchen", "k": "キッチン", "p": "名詞", "m": ["だいどころ", "キッチン"], "ex": "My mother is cooking in the kitchen.", "level": 1, "exj": "お母さんは台所で料理をしています。"}, {"id": 51, "w": "letter", "k": "レター", "p": "名詞", "m": ["てがみ", "文字"], "ex": "I wrote a letter to my grandmother.", "level": 1, "exj": "私はおばあちゃんに手紙を書きました。"}, {"id": 52, "w": "money", "k": "マネー", "p": "名詞", "m": ["お金"], "ex": "I don't have enough money.", "level": 1, "exj": "お金が足りません。"}, {"id": 53, "w": "night", "k": "ナイト", "p": "名詞", "m": ["よる", "夜"], "ex": "Good night, everyone.", "level": 1, "exj": "おやすみなさい、みなさん。"}, {"id": 54, "w": "picture", "k": "ピクチャー", "p": "名詞", "m": ["絵", "写真"], "ex": "She drew a nice picture.", "level": 1, "exj": "彼女は上手な絵を描きました。"}, {"id": 55, "w": "room", "k": "ルーム", "p": "名詞", "m": ["へや"], "ex": "My room is on the second floor.", "level": 1, "exj": "私の部屋は2階にあります。"}, {"id": 56, "w": "star", "k": "スター", "p": "名詞", "m": ["ほし", "スター"], "ex": "The stars look beautiful tonight.", "level": 1, "exj": "今夜は星がきれいに見えます。"}, {"id": 57, "w": "time", "k": "タイム", "p": "名詞", "m": ["じかん", "時刻"], "ex": "What time is it now?", "level": 1, "exj": "今、何時ですか？"}, {"id": 58, "w": "voice", "k": "ボイス", "p": "名詞", "m": ["こえ"], "ex": "She has a beautiful voice.", "level": 1, "exj": "彼女はきれいな声をしています。"}, {"id": 59, "w": "word", "k": "ワード", "p": "名詞", "m": ["たんご", "ことば"], "ex": "I learned ten new words today.", "level": 1, "exj": "私は今日10個の新しい単語を覚えました。"}, {"id": 60, "w": "arm", "k": "アーム", "p": "名詞", "m": ["うで", "腕"], "ex": "She broke her arm during soccer practice.", "level": 1, "exj": "彼女はサッカーの練習中に腕を骨折しました。"}, {"id": 61, "w": "color", "k": "カラー", "p": "名詞", "m": ["いろ"], "ex": "What is your favorite color?", "level": 1, "exj": "好きな色は何ですか？"}, {"id": 62, "w": "dream", "k": "ドリーム", "p": "名詞", "m": ["ゆめ"], "ex": "I had a strange dream last night.", "level": 1, "exj": "昨夜、不思議な夢を見ました。"}, {"id": 63, "w": "earth", "k": "アース", "p": "名詞", "m": ["地球", "つち"], "ex": "The earth goes around the sun.", "level": 1, "exj": "地球は太陽の周りを回っています。"}, {"id": 64, "w": "family", "k": "ファミリー", "p": "名詞", "m": ["かぞく"], "ex": "My family has four members.", "level": 1, "exj": "私の家族は4人です。"}, {"id": 65, "w": "friend", "k": "フレンド", "p": "名詞", "m": ["ともだち"], "ex": "She is my best friend.", "level": 1, "exj": "彼女は私の親友です。"}, {"id": 66, "w": "group", "k": "グループ", "p": "名詞", "m": ["グループ", "なかま"], "ex": "We worked in groups.", "level": 1, "exj": "私たちはグループで活動しました。"}, {"id": 67, "w": "hobby", "k": "ホビー", "p": "名詞", "m": ["しゅみ"], "ex": "My hobby is playing soccer.", "level": 1, "exj": "私の趣味はサッカーをすることです。"}, {"id": 68, "w": "month", "k": "マンス", "p": "名詞", "m": ["月"], "ex": "January is the first month of the year.", "level": 1, "exj": "1月は1年の最初の月です。"}, {"id": 69, "w": "music", "k": "ミュージック", "p": "名詞", "m": ["おんがく"], "ex": "I love listening to music.", "level": 1, "exj": "私は音楽を聴くのが大好きです。"}, {"id": 70, "w": "place", "k": "プレイス", "p": "名詞", "m": ["ばしょ", "場所"], "ex": "This is a nice place to rest.", "level": 1, "exj": "ここは休憩するのにいい場所です。"}, {"id": 71, "w": "sleep", "k": "スリープ", "p": "名詞", "m": ["ねむり", "すいみん"], "ex": "I need more sleep.", "level": 2, "exj": "もっと眠る必要があります。"}, {"id": 72, "w": "smile", "k": "スマイル", "p": "名詞", "m": ["ほほえみ", "笑顔"], "ex": "She has a beautiful smile.", "level": 2, "exj": "彼女はとてもすてきな笑顔をしています。"}, {"id": 73, "w": "sport", "k": "スポーツ", "p": "名詞", "m": ["スポーツ"], "ex": "What sport do you play?", "level": 2, "exj": "どんなスポーツをしますか？"}, {"id": 74, "w": "story", "k": "ストーリー", "p": "名詞", "m": ["話", "物語"], "ex": "Tell me a story.", "level": 2, "exj": "お話を聞かせてください。"}, {"id": 75, "w": "street", "k": "ストリート", "p": "名詞", "m": ["道", "通り"], "ex": "There are many shops on this street.", "level": 2, "exj": "この通りにはたくさんのお店があります。"}, {"id": 76, "w": "summer", "k": "サマー", "p": "名詞", "m": ["なつ"], "ex": "Summer is my favorite season.", "level": 2, "exj": "夏は私の一番好きな季節です。"}, {"id": 77, "w": "teacher", "k": "ティーチャー", "p": "名詞", "m": ["先生", "教師"], "ex": "My teacher is very kind.", "level": 2, "exj": "私の先生はとても優しいです。"}, {"id": 78, "w": "today", "k": "トゥデイ", "p": "名詞", "m": ["きょう", "今日"], "ex": "What are you doing today?", "level": 2, "exj": "今日は何をしていますか？"}, {"id": 79, "w": "town", "k": "タウン", "p": "名詞", "m": ["まち"], "ex": "I grew up in a small town.", "level": 2, "exj": "私は小さな町で育ちました。"}, {"id": 80, "w": "train", "k": "トレイン", "p": "名詞", "m": ["でんしゃ"], "ex": "I take the train to school.", "level": 2, "exj": "私は電車で学校へ行きます。"}, {"id": 81, "w": "trip", "k": "トリップ", "p": "名詞", "m": ["旅行", "遠足"], "ex": "We went on a school trip last month.", "level": 2, "exj": "先月、修学旅行に行きました。"}, {"id": 82, "w": "vegetable", "k": "ベジタブル", "p": "名詞", "m": ["やさい"], "ex": "Eat more vegetables.", "level": 2, "exj": "もっと野菜を食べましょう。"}, {"id": 83, "w": "village", "k": "ビレッジ", "p": "名詞", "m": ["むら", "村"], "ex": "I live in a small village.", "level": 2, "exj": "私は小さな村に住んでいます。"}, {"id": 84, "w": "weekend", "k": "ウィークエンド", "p": "名詞", "m": ["週末"], "ex": "What will you do this weekend?", "level": 2, "exj": "この週末は何をしますか？"}, {"id": 85, "w": "animal", "k": "アニマル", "p": "名詞", "m": ["どうぶつ"], "ex": "I like animals very much.", "level": 2, "exj": "私は動物がとても好きです。"}, {"id": 86, "w": "birthday", "k": "バースデイ", "p": "名詞", "m": ["たんじょうび"], "ex": "Happy birthday to you!", "level": 2, "exj": "お誕生日おめでとう！"}, {"id": 87, "w": "bread", "k": "ブレッド", "p": "名詞", "m": ["パン"], "ex": "I eat bread for breakfast.", "level": 2, "exj": "私は朝食にパンを食べます。"}, {"id": 88, "w": "brother", "k": "ブラザー", "p": "名詞", "m": ["おにいさん（兄）", "おとうと（弟）"], "ex": "My brother is good at math.", "level": 2, "exj": "私の兄は算数が得意です。"}, {"id": 89, "w": "butter", "k": "バター", "p": "名詞", "m": ["バター"], "ex": "I put butter on my toast.", "level": 2, "exj": "私はトーストにバターを塗ります。"}, {"id": 90, "w": "camera", "k": "カメラ", "p": "名詞", "m": ["カメラ"], "ex": "I took pictures with my camera.", "level": 2, "exj": "私はカメラで写真を撮りました。"}, {"id": 91, "w": "chair", "k": "チェア", "p": "名詞", "m": ["いす"], "ex": "Please have a seat in this chair.", "level": 2, "exj": "この椅子に座ってください。"}, {"id": 92, "w": "church", "k": "チャーチ", "p": "名詞", "m": ["きょうかい"], "ex": "There is an old church in our town.", "level": 2, "exj": "私たちの町には古い教会があります。"}, {"id": 93, "w": "class", "k": "クラス", "p": "名詞", "m": ["クラス", "じゅぎょう"], "ex": "English class starts at nine.", "level": 2, "exj": "英語の授業は9時に始まります。"}, {"id": 94, "w": "cloud", "k": "クラウド", "p": "名詞", "m": ["くも"], "ex": "The clouds are dark today.", "level": 2, "exj": "今日は雲が暗いです。"}, {"id": 95, "w": "cookie", "k": "クッキー", "p": "名詞", "m": ["クッキー"], "ex": "She baked some cookies.", "level": 2, "exj": "彼女はクッキーを焼きました。"}, {"id": 96, "w": "corner", "k": "コーナー", "p": "名詞", "m": ["かど", "コーナー"], "ex": "Turn left at the corner.", "level": 2, "exj": "角を左に曲がってください。"}, {"id": 97, "w": "cousin", "k": "カズン", "p": "名詞", "m": ["いとこ"], "ex": "My cousin visited us last week.", "level": 2, "exj": "私のいとこが先週遊びに来ました。"}, {"id": 98, "w": "danger", "k": "デンジャー", "p": "名詞", "m": ["きけん"], "ex": "There is danger ahead.", "level": 2, "exj": "前に危険があります。"}, {"id": 99, "w": "dinner", "k": "ディナー", "p": "名詞", "m": ["ゆうしょく", "夕食"], "ex": "Dinner is ready.", "level": 2, "exj": "夕食ができました。"}, {"id": 100, "w": "doctor", "k": "ドクター", "p": "名詞", "m": ["いしゃ", "医者"], "ex": "I went to see the doctor.", "level": 2, "exj": "私は病院に行きました。"}, {"id": 101, "w": "go", "k": "ゴー", "p": "動詞", "m": ["行く"], "ex": "Let's go to the park.", "level": 1, "exj": "公園へ行きましょう。"}, {"id": 102, "w": "come", "k": "カム", "p": "動詞", "m": ["来る"], "ex": "Please come here.", "level": 1, "exj": "こちらへ来てください。"}, {"id": 103, "w": "eat", "k": "イート", "p": "動詞", "m": ["食べる"], "ex": "I eat breakfast every morning.", "level": 1, "exj": "私は毎朝朝食を食べます。"}, {"id": 104, "w": "drink", "k": "ドリンク", "p": "動詞", "m": ["飲む"], "ex": "I drink water after exercise.", "level": 1, "exj": "運動の後、水を飲みます。"}, {"id": 105, "w": "play", "k": "プレイ", "p": "動詞", "m": ["遊ぶ", "〜をする（スポーツ）"], "ex": "I play soccer on Saturdays.", "level": 1, "exj": "私は土曜日にサッカーをします。"}, {"id": 106, "w": "like", "k": "ライク", "p": "動詞", "m": ["〜が好きだ"], "ex": "I like Japanese food.", "level": 1, "exj": "私は日本食が好きです。"}, {"id": 107, "w": "love", "k": "ラブ", "p": "動詞", "m": ["〜が大好きだ", "愛する"], "ex": "I love my family.", "level": 1, "exj": "私は家族を愛しています。"}, {"id": 108, "w": "have", "k": "ハブ", "p": "動詞", "m": ["持つ", "〜がある"], "ex": "I have two brothers.", "level": 1, "exj": "私には兄弟が2人います。"}, {"id": 109, "w": "see", "k": "シー", "p": "動詞", "m": ["見る", "会う"], "ex": "I can see the mountains from here.", "level": 1, "exj": "ここから山が見えます。"}, {"id": 110, "w": "look", "k": "ルック", "p": "動詞", "m": ["見る", "〜のように見える"], "ex": "Look at that beautiful rainbow!", "level": 1, "exj": "あの美しい虹を見て！"}, {"id": 111, "w": "listen", "k": "リスン", "p": "動詞", "m": ["聞く"], "ex": "Please listen carefully.", "level": 1, "exj": "注意して聞いてください。"}, {"id": 112, "w": "speak", "k": "スピーク", "p": "動詞", "m": ["話す"], "ex": "Can you speak English?", "level": 1, "exj": "英語を話せますか？"}, {"id": 113, "w": "talk", "k": "トーク", "p": "動詞", "m": ["話す", "話し合う"], "ex": "Let's talk about it later.", "level": 1, "exj": "後で話し合いましょう。"}, {"id": 114, "w": "read", "k": "リード", "p": "動詞", "m": ["読む"], "ex": "I read books every night.", "level": 1, "exj": "私は毎晩本を読みます。"}, {"id": 115, "w": "write", "k": "ライト", "p": "動詞", "m": ["書く"], "ex": "Please write your name here.", "level": 1, "exj": "ここに名前を書いてください。"}, {"id": 116, "w": "study", "k": "スタディ", "p": "動詞", "m": ["勉強する"], "ex": "I study English every day.", "level": 1, "exj": "私は毎日英語を勉強しています。"}, {"id": 117, "w": "learn", "k": "ラーン", "p": "動詞", "m": ["学ぶ", "習う"], "ex": "I want to learn French.", "level": 1, "exj": "フランス語を学びたいです。"}, {"id": 118, "w": "know", "k": "ノウ", "p": "動詞", "m": ["知っている"], "ex": "Do you know the answer?", "level": 1, "exj": "答えを知っていますか？"}, {"id": 119, "w": "think", "k": "シンク", "p": "動詞", "m": ["思う", "考える"], "ex": "I think it's a good idea.", "level": 1, "exj": "それはいい考えだと思います。"}, {"id": 120, "w": "want", "k": "ウォント", "p": "動詞", "m": ["〜がほしい", "〜したい"], "ex": "I want to visit Japan.", "level": 1, "exj": "日本を訪れたいです。"}, {"id": 121, "w": "use", "k": "ユーズ", "p": "動詞", "m": ["使う"], "ex": "May I use your phone?", "level": 1, "exj": "あなたの電話を使ってもいいですか？"}, {"id": 122, "w": "make", "k": "メイク", "p": "動詞", "m": ["作る", "〜させる"], "ex": "Can you make a sandwich?", "level": 1, "exj": "サンドイッチを作ってもらえますか？"}, {"id": 123, "w": "take", "k": "テイク", "p": "動詞", "m": ["取る", "持って行く"], "ex": "Please take this letter.", "level": 1, "exj": "この手紙を受け取ってください。"}, {"id": 124, "w": "give", "k": "ギブ", "p": "動詞", "m": ["あげる", "与える"], "ex": "I gave her a birthday present.", "level": 1, "exj": "私は彼女に誕生日プレゼントをあげました。"}, {"id": 125, "w": "get", "k": "ゲット", "p": "動詞", "m": ["もらう", "手に入れる"], "ex": "I got a good score on the test.", "level": 1, "exj": "私はテストで良い点を取りました。"}, {"id": 126, "w": "put", "k": "プット", "p": "動詞", "m": ["置く"], "ex": "Please put it on the desk.", "level": 1, "exj": "机の上に置いてください。"}, {"id": 127, "w": "open", "k": "オープン", "p": "動詞", "m": ["開ける", "開く"], "ex": "Please open the window.", "level": 1, "exj": "窓を開けてください。"}, {"id": 128, "w": "close", "k": "クローズ", "p": "動詞", "m": ["閉める", "閉まる"], "ex": "Close the door, please.", "level": 1, "exj": "ドアを閉めてください。"}, {"id": 129, "w": "help", "k": "ヘルプ", "p": "動詞", "m": ["助ける", "手伝う"], "ex": "Can you help me with this?", "level": 1, "exj": "これを手伝ってもらえますか？"}, {"id": 130, "w": "stop", "k": "ストップ", "p": "動詞", "m": ["止まる", "やめる"], "ex": "Please stop running in the hall.", "level": 1, "exj": "廊下で走るのをやめてください。"}, {"id": 131, "w": "start", "k": "スタート", "p": "動詞", "m": ["始まる", "始める"], "ex": "Class starts at eight.", "level": 1, "exj": "授業は8時に始まります。"}, {"id": 132, "w": "run", "k": "ラン", "p": "動詞", "m": ["走る"], "ex": "She can run very fast.", "level": 1, "exj": "彼女はとても速く走れます。"}, {"id": 133, "w": "walk", "k": "ウォーク", "p": "動詞", "m": ["歩く"], "ex": "I walk to school every day.", "level": 1, "exj": "私は毎日歩いて学校へ行きます。"}, {"id": 134, "w": "swim", "k": "スウィム", "p": "動詞", "m": ["泳ぐ"], "ex": "Can you swim?", "level": 1, "exj": "泳げますか？"}, {"id": 135, "w": "sing", "k": "シング", "p": "動詞", "m": ["歌う"], "ex": "She sings beautifully.", "level": 1, "exj": "彼女は上手に歌います。"}, {"id": 136, "w": "dance", "k": "ダンス", "p": "動詞", "m": ["踊る"], "ex": "He dances at parties.", "level": 1, "exj": "彼はパーティーで踊ります。"}, {"id": 137, "w": "draw", "k": "ドロー", "p": "動詞", "m": ["絵を描く"], "ex": "I like to draw pictures.", "level": 1, "exj": "私は絵を描くのが好きです。"}, {"id": 138, "w": "cook", "k": "クック", "p": "動詞", "m": ["料理する"], "ex": "My father cooks dinner on weekends.", "level": 1, "exj": "私の父は週末に夕食を作ります。"}, {"id": 139, "w": "clean", "k": "クリーン", "p": "動詞", "m": ["掃除する", "きれいにする"], "ex": "Please clean your room.", "level": 1, "exj": "部屋を掃除してください。"}, {"id": 140, "w": "buy", "k": "バイ", "p": "動詞", "m": ["買う"], "ex": "I want to buy a new bag.", "level": 1, "exj": "新しいかばんを買いたいです。"}, {"id": 141, "w": "send", "k": "センド", "p": "動詞", "m": ["送る"], "ex": "I sent her an email.", "level": 2, "exj": "私は彼女にメールを送りました。"}, {"id": 142, "w": "show", "k": "ショウ", "p": "動詞", "m": ["見せる", "案内する"], "ex": "Show me your homework.", "level": 2, "exj": "宿題を見せてください。"}, {"id": 143, "w": "ask", "k": "アスク", "p": "動詞", "m": ["たずねる", "頼む"], "ex": "May I ask you a question?", "level": 2, "exj": "質問してもいいですか？"}, {"id": 144, "w": "answer", "k": "アンサー", "p": "動詞", "m": ["答える"], "ex": "Please answer the question.", "level": 2, "exj": "質問に答えてください。"}, {"id": 145, "w": "call", "k": "コール", "p": "動詞", "m": ["電話する", "呼ぶ"], "ex": "I will call you later.", "level": 2, "exj": "後で電話します。"}, {"id": 146, "w": "wait", "k": "ウェイト", "p": "動詞", "m": ["待つ"], "ex": "Please wait for me here.", "level": 2, "exj": "ここで待っていてください。"}, {"id": 147, "w": "try", "k": "トライ", "p": "動詞", "m": ["試みる", "やってみる"], "ex": "Try your best!", "level": 2, "exj": "ベストを尽くしてください！"}, {"id": 148, "w": "need", "k": "ニード", "p": "動詞", "m": ["必要とする"], "ex": "I need your help.", "level": 2, "exj": "助けが必要です。"}, {"id": 149, "w": "find", "k": "ファインド", "p": "動詞", "m": ["見つける"], "ex": "I can't find my pencil.", "level": 2, "exj": "鉛筆が見つかりません。"}, {"id": 150, "w": "bring", "k": "ブリング", "p": "動詞", "m": ["持ってくる"], "ex": "Please bring your textbook tomorrow.", "level": 2, "exj": "明日、教科書を持ってきてください。"}, {"id": 151, "w": "big", "k": "ビッグ", "p": "形容詞", "m": ["大きい"], "ex": "An elephant is a big animal.", "level": 1, "exj": "ゾウは大きな動物です。"}, {"id": 152, "w": "small", "k": "スモール", "p": "形容詞", "m": ["小さい"], "ex": "My house is small but cozy.", "level": 1, "exj": "私の家は小さいですが居心地がいいです。"}, {"id": 153, "w": "good", "k": "グッド", "p": "形容詞", "m": ["よい", "上手な"], "ex": "You did a good job!", "level": 1, "exj": "よくできました！"}, {"id": 154, "w": "bad", "k": "バッド", "p": "形容詞", "m": ["悪い"], "ex": "Today is a bad day.", "level": 1, "exj": "今日はついていない日です。"}, {"id": 155, "w": "new", "k": "ニュー", "p": "形容詞", "m": ["新しい"], "ex": "I got a new phone.", "level": 1, "exj": "新しいスマートフォンをもらいました。"}, {"id": 156, "w": "old", "k": "オールド", "p": "形容詞", "m": ["古い", "年をとった"], "ex": "This is an old building.", "level": 1, "exj": "これは古い建物です。"}, {"id": 157, "w": "long", "k": "ロング", "p": "形容詞", "m": ["長い"], "ex": "She has long hair.", "level": 1, "exj": "彼女は長い髪をしています。"}, {"id": 158, "w": "short", "k": "ショート", "p": "形容詞", "m": ["短い", "背が低い"], "ex": "He is short but strong.", "level": 1, "exj": "彼は背が低いですが強いです。"}, {"id": 159, "w": "hot", "k": "ホット", "p": "形容詞", "m": ["熱い", "暑い"], "ex": "It is very hot today.", "level": 1, "exj": "今日はとても暑いです。"}, {"id": 160, "w": "cold", "k": "コールド", "p": "形容詞", "m": ["冷たい", "寒い"], "ex": "The water is cold.", "level": 1, "exj": "その水は冷たいです。"}, {"id": 161, "w": "happy", "k": "ハッピー", "p": "形容詞", "m": ["うれしい", "幸せな"], "ex": "I am very happy today.", "level": 1, "exj": "今日はとても嬉しいです。"}, {"id": 162, "w": "sad", "k": "サッド", "p": "形容詞", "m": ["悲しい"], "ex": "She looked sad after hearing the news.", "level": 1, "exj": "彼女はそのニュースを聞いて悲しそうでした。"}, {"id": 163, "w": "tired", "k": "タイアード", "p": "形容詞", "m": ["疲れた"], "ex": "I am tired after practice.", "level": 1, "exj": "練習の後、疲れています。"}, {"id": 164, "w": "busy", "k": "ビジー", "p": "形容詞", "m": ["いそがしい"], "ex": "She is busy with homework.", "level": 1, "exj": "彼女は宿題で忙しいです。"}, {"id": 165, "w": "easy", "k": "イージー", "p": "形容詞", "m": ["簡単な", "やさしい"], "ex": "This quiz is easy.", "level": 1, "exj": "このクイズは簡単です。"}, {"id": 166, "w": "hard", "k": "ハード", "p": "形容詞", "m": ["難しい", "固い"], "ex": "Math is hard for me.", "level": 1, "exj": "算数は私には難しいです。"}, {"id": 167, "w": "fast", "k": "ファスト", "p": "形容詞", "m": ["速い"], "ex": "He is a fast runner.", "level": 1, "exj": "彼は足が速い走者です。"}, {"id": 168, "w": "slow", "k": "スロウ", "p": "形容詞", "m": ["遅い", "ゆっくりした"], "ex": "Please speak slowly.", "level": 1, "exj": "ゆっくり話してください。"}, {"id": 169, "w": "tall", "k": "トール", "p": "形容詞", "m": ["背が高い", "高い"], "ex": "My brother is very tall.", "level": 1, "exj": "私の兄はとても背が高いです。"}, {"id": 170, "w": "kind", "k": "カインド", "p": "形容詞", "m": ["親切な", "やさしい"], "ex": "She is very kind to everyone.", "level": 1, "exj": "彼女は誰にでも優しいです。"}, {"id": 171, "w": "cute", "k": "キュート", "p": "形容詞", "m": ["かわいい"], "ex": "What a cute puppy!", "level": 1, "exj": "なんてかわいい子犬でしょう！"}, {"id": 172, "w": "funny", "k": "ファニー", "p": "形容詞", "m": ["おかしい", "おもしろい"], "ex": "He always tells funny jokes.", "level": 1, "exj": "彼はいつも面白い冗談を言います。"}, {"id": 173, "w": "nice", "k": "ナイス", "p": "形容詞", "m": ["すてきな", "良い"], "ex": "What a nice day!", "level": 1, "exj": "なんていい天気でしょう！"}, {"id": 174, "w": "great", "k": "グレート", "p": "形容詞", "m": ["すばらしい", "偉大な"], "ex": "That's a great idea!", "level": 1, "exj": "それはすばらしい考えですね！"}, {"id": 175, "w": "beautiful", "k": "ビューティフル", "p": "形容詞", "m": ["美しい", "きれいな"], "ex": "The sunset is beautiful.", "level": 1, "exj": "夕日はきれいです。"}, {"id": 176, "w": "young", "k": "ヤング", "p": "形容詞", "m": ["若い"], "ex": "She looks very young.", "level": 2, "exj": "彼女はとても若く見えます。"}, {"id": 177, "w": "sick", "k": "シック", "p": "形容詞", "m": ["病気の", "気分が悪い"], "ex": "I stayed home because I was sick.", "level": 2, "exj": "体調が悪いので家にいました。"}, {"id": 178, "w": "late", "k": "レイト", "p": "形容詞", "m": ["遅い", "遅れた"], "ex": "Sorry I am late.", "level": 2, "exj": "遅れてすみません。"}, {"id": 179, "w": "early", "k": "アーリー", "p": "形容詞", "m": ["早い", "早く"], "ex": "I get up early every morning.", "level": 2, "exj": "私は毎朝早く起きます。"}, {"id": 180, "w": "free", "k": "フリー", "p": "形容詞", "m": ["ひまな", "無料の"], "ex": "Are you free this afternoon?", "level": 2, "exj": "今日の午後は暇ですか？"}, {"id": 181, "w": "right", "k": "ライト", "p": "形容詞", "m": ["正しい", "右の"], "ex": "Turn right at the corner.", "level": 2, "exj": "角を右に曲がってください。"}, {"id": 182, "w": "wrong", "k": "ローング", "p": "形容詞", "m": ["まちがっている"], "ex": "Sorry, that's the wrong answer.", "level": 2, "exj": "すみません、それは間違いです。"}, {"id": 183, "w": "safe", "k": "セイフ", "p": "形容詞", "m": ["安全な"], "ex": "Is this area safe?", "level": 2, "exj": "このエリアは安全ですか？"}, {"id": 184, "w": "dirty", "k": "ダーティ", "p": "形容詞", "m": ["きたない", "汚い"], "ex": "Your shoes are dirty. Please clean them.", "level": 2, "exj": "靴が汚れています。きれいにしてください。"}, {"id": 185, "w": "dark", "k": "ダーク", "p": "形容詞", "m": ["暗い", "濃い色の"], "ex": "It gets dark early in winter.", "level": 2, "exj": "冬は早く暗くなります。"}, {"id": 186, "w": "always", "k": "オールウェイズ", "p": "副詞", "m": ["いつも"], "ex": "I always brush my teeth before bed.", "level": 1, "exj": "私はいつも寝る前に歯を磨きます。"}, {"id": 187, "w": "often", "k": "オーフン", "p": "副詞", "m": ["よく", "しばしば"], "ex": "We often go hiking.", "level": 1, "exj": "私たちはよくハイキングに行きます。"}, {"id": 188, "w": "sometimes", "k": "サムタイムズ", "p": "副詞", "m": ["ときどき"], "ex": "I sometimes watch movies.", "level": 1, "exj": "私は時々映画を見ます。"}, {"id": 189, "w": "never", "k": "ネバー", "p": "副詞", "m": ["決して〜ない"], "ex": "I never give up.", "level": 1, "exj": "私は絶対にあきらめません。"}, {"id": 190, "w": "very", "k": "ベリー", "p": "副詞", "m": ["とても", "非常に"], "ex": "I am very happy.", "level": 1, "exj": "私はとても嬉しいです。"}, {"id": 191, "w": "too", "k": "トゥー", "p": "副詞", "m": ["〜も", "あまりにも"], "ex": "I like it too.", "level": 1, "exj": "私もそれが好きです。"}, {"id": 192, "w": "really", "k": "リアリー", "p": "副詞", "m": ["本当に", "とても"], "ex": "I really like this song.", "level": 1, "exj": "私もスポーツが好きです。"}, {"id": 193, "w": "also", "k": "オールソー", "p": "副詞", "m": ["〜もまた"], "ex": "I also like sports.", "level": 1, "exj": "こちらへ来てください。"}, {"id": 194, "w": "here", "k": "ヒア", "p": "副詞", "m": ["ここに", "ここで"], "ex": "Come here, please.", "level": 1, "exj": "私の家の近くに公園があります。"}, {"id": 195, "w": "there", "k": "ゼア", "p": "副詞", "m": ["そこに", "あそこに"], "ex": "There is a park near my house.", "level": 1, "exj": "今、何をしていますか？"}, {"id": 196, "w": "now", "k": "ナウ", "p": "副詞", "m": ["今", "ただいま"], "ex": "What are you doing now?", "level": 1, "exj": "まず勉強して、それから遊びましょう。"}, {"id": 197, "w": "then", "k": "ゼン", "p": "副詞", "m": ["そのとき", "それから"], "ex": "First study, then play.", "level": 1, "exj": "ちょうど宿題が終わりました。"}, {"id": 198, "w": "just", "k": "ジャスト", "p": "副詞", "m": ["ちょうど", "ただ〜だけ"], "ex": "I just finished my homework.", "level": 1, "exj": "明日は雨が降るかもしれません。"}, {"id": 199, "w": "maybe", "k": "メイビー", "p": "副詞", "m": ["たぶん"], "ex": "Maybe it will rain tomorrow.", "level": 1, "exj": "一緒にこれをやりましょう。"}, {"id": 200, "w": "together", "k": "トゥゲザー", "p": "副詞", "m": ["いっしょに"], "ex": "Let's do this together.", "level": 1, "exj": "私の母は先生です。"}, {"id": 201, "w": "mother", "k": "マザー", "p": "名詞", "m": ["母", "お母さん"], "ex": "My mother is a teacher.", "level": 1, "exj": "私の父は週末に料理をします。"}, {"id": 202, "w": "father", "k": "ファーザー", "p": "名詞", "m": ["父", "お父さん"], "ex": "My father cooks on weekends.", "level": 1, "exj": "私の姉は音楽が好きです。"}, {"id": 203, "w": "sister", "k": "シスター", "p": "名詞", "m": ["姉", "妹"], "ex": "My sister likes music.", "level": 1, "exj": "赤ちゃんが寝ています。"}, {"id": 204, "w": "baby", "k": "ベイビー", "p": "名詞", "m": ["赤ちゃん"], "ex": "The baby is sleeping.", "level": 1, "exj": "すべての子どもは遊ぶのが好きです。"}, {"id": 205, "w": "child", "k": "チャイルド", "p": "名詞", "m": ["子ども"], "ex": "Every child loves playing.", "level": 1, "exj": "その男性は医者です。"}, {"id": 206, "w": "man", "k": "マン", "p": "名詞", "m": ["男性", "男の人"], "ex": "The man is a doctor.", "level": 1, "exj": "その女性は私の先生です。"}, {"id": 207, "w": "woman", "k": "ウーマン", "p": "名詞", "m": ["女性", "女の人"], "ex": "The woman is my teacher.", "level": 1, "exj": "その男の子はサッカーをしています。"}, {"id": 208, "w": "boy", "k": "ボーイ", "p": "名詞", "m": ["男の子"], "ex": "The boy is playing soccer.", "level": 1, "exj": "たくさんの人がお祭りに来ました。"}, {"id": 209, "w": "people", "k": "ピープル", "p": "名詞", "m": ["人々", "人"], "ex": "Many people came to the festival.", "level": 1, "exj": "彼女は優しい人です。"}, {"id": 210, "w": "person", "k": "パーソン", "p": "名詞", "m": ["人"], "ex": "She is a kind person.", "level": 1, "exj": "おはようございます、みなさん。"}, {"id": 211, "w": "morning", "k": "モーニング", "p": "名詞", "m": ["朝", "午前"], "ex": "Good morning, everyone.", "level": 1, "exj": "今日の午後はピアノの授業があります。"}, {"id": 212, "w": "afternoon", "k": "アフタヌーン", "p": "名詞", "m": ["午後"], "ex": "I have piano class this afternoon.", "level": 1, "exj": "こんにちは！"}, {"id": 213, "w": "evening", "k": "イブニング", "p": "名詞", "m": ["夕方", "夜"], "ex": "Good evening!", "level": 1, "exj": "私は週に3回サッカーの練習をします。"}, {"id": 214, "w": "week", "k": "ウィーク", "p": "名詞", "m": ["週"], "ex": "I practice soccer three times a week.", "level": 1, "exj": "今夜は空いていますか？"}, {"id": 215, "w": "tonight", "k": "トゥナイト", "p": "副詞", "m": ["こんばん", "今夜"], "ex": "Are you free tonight?", "level": 1, "exj": "昨日、祖父母の家を訪れました。"}, {"id": 216, "w": "yesterday", "k": "イエスタデイ", "p": "副詞", "m": ["きのう"], "ex": "I visited my grandparents yesterday.", "level": 1, "exj": "明日はテストがあります。"}, {"id": 217, "w": "tomorrow", "k": "トゥモロウ", "p": "副詞", "m": ["あした"], "ex": "I have a test tomorrow.", "level": 1, "exj": "私は日曜日に休みます。"}, {"id": 218, "w": "Sunday", "k": "サンデイ", "p": "名詞", "m": ["日曜日"], "ex": "I rest on Sunday.", "level": 1, "exj": "月曜日に学校が始まります。"}, {"id": 219, "w": "Monday", "k": "マンデイ", "p": "名詞", "m": ["月曜日"], "ex": "School starts on Monday.", "level": 1, "exj": "火曜日に英語があります。"}, {"id": 220, "w": "Tuesday", "k": "チューズデイ", "p": "名詞", "m": ["火曜日"], "ex": "I have English on Tuesday.", "level": 1, "exj": "水曜日にクラブがあります。"}, {"id": 221, "w": "Wednesday", "k": "ウェンズデイ", "p": "名詞", "m": ["水曜日"], "ex": "We have a club on Wednesday.", "level": 1, "exj": "木曜日に水泳があります。"}, {"id": 222, "w": "Thursday", "k": "サーズデイ", "p": "名詞", "m": ["木曜日"], "ex": "I swim on Thursday.", "level": 1, "exj": "金曜日は私の好きな曜日です。"}, {"id": 223, "w": "Friday", "k": "フライデイ", "p": "名詞", "m": ["金曜日"], "ex": "Friday is my favorite day.", "level": 1, "exj": "土曜日に野球をします。"}, {"id": 224, "w": "Saturday", "k": "サタデイ", "p": "名詞", "m": ["土曜日"], "ex": "I play baseball on Saturday.", "level": 1, "exj": "私の誕生日は1月です。"}, {"id": 225, "w": "January", "k": "ジャニュアリー", "p": "名詞", "m": ["1月"], "ex": "My birthday is in January.", "level": 2, "exj": "バレンタインデーは2月です。"}, {"id": 226, "w": "February", "k": "フェブラリー", "p": "名詞", "m": ["2月"], "ex": "Valentine's Day is in February.", "level": 2, "exj": "3月には桜が咲きます。"}, {"id": 227, "w": "March", "k": "マーチ", "p": "名詞", "m": ["3月"], "ex": "Cherry blossoms bloom in March.", "level": 2, "exj": "エイプリルフールは4月1日です。"}, {"id": 228, "w": "April", "k": "エイプリル", "p": "名詞", "m": ["4月"], "ex": "April Fools' Day is April 1st.", "level": 2, "exj": "ゴールデンウィークは5月です。"}, {"id": 229, "w": "May", "k": "メイ", "p": "名詞", "m": ["5月"], "ex": "Golden Week is in May.", "level": 2, "exj": "6月はたくさん雨が降ります。"}, {"id": 230, "w": "June", "k": "ジューン", "p": "名詞", "m": ["6月"], "ex": "It rains a lot in June.", "level": 2, "exj": "7月にキャンプに行きます。"}, {"id": 231, "w": "July", "k": "ジュライ", "p": "名詞", "m": ["7月"], "ex": "I go to camp in July.", "level": 2, "exj": "夏休みは8月です。"}, {"id": 232, "w": "August", "k": "オーガスト", "p": "名詞", "m": ["8月"], "ex": "Summer vacation is in August.", "level": 2, "exj": "9月に学校が再び始まります。"}, {"id": 233, "w": "September", "k": "セプテンバー", "p": "名詞", "m": ["9月"], "ex": "School starts again in September.", "level": 2, "exj": "10月にはハロウィンがあります。"}, {"id": 234, "w": "October", "k": "オクトーバー", "p": "名詞", "m": ["10月"], "ex": "Halloween is in October.", "level": 2, "exj": "11月は寒くなります。"}, {"id": 235, "w": "November", "k": "ノベンバー", "p": "名詞", "m": ["11月"], "ex": "It gets cold in November.", "level": 2, "exj": "12月にはクリスマスがあります。"}, {"id": 236, "w": "December", "k": "ディセンバー", "p": "名詞", "m": ["12月"], "ex": "Christmas is in December.", "level": 2, "exj": "私は春の花が大好きです。"}, {"id": 237, "w": "spring", "k": "スプリング", "p": "名詞", "m": ["春"], "ex": "I love spring flowers.", "level": 2, "exj": "雪があるから冬が好きです。"}, {"id": 238, "w": "winter", "k": "ウィンター", "p": "名詞", "m": ["冬"], "ex": "I like winter because of snow.", "level": 2, "exj": "秋には葉っぱが赤くなります。"}, {"id": 239, "w": "autumn", "k": "オータム", "p": "名詞", "m": ["秋"], "ex": "Leaves turn red in autumn.", "level": 2, "exj": "今日は天気がいいです。"}, {"id": 240, "w": "weather", "k": "ウェザー", "p": "名詞", "m": ["天気", "天候"], "ex": "The weather is nice today.", "level": 2, "exj": "今日は晴れています。"}, {"id": 241, "w": "sunny", "k": "サニー", "p": "形容詞", "m": ["晴れた", "晴れの"], "ex": "It is a sunny day.", "level": 2, "exj": "外は風が強いです。"}, {"id": 242, "w": "windy", "k": "ウィンディ", "p": "形容詞", "m": ["風の強い"], "ex": "It is windy outside.", "level": 2, "exj": "雪が降る朝でした。"}, {"id": 243, "w": "snowy", "k": "スノーウィ", "p": "形容詞", "m": ["雪の降る"], "ex": "It was a snowy morning.", "level": 2, "exj": "今日は曇っています。"}, {"id": 244, "w": "cloudy", "k": "クラウディ", "p": "形容詞", "m": ["くもった", "曇りの"], "ex": "It is cloudy today.", "level": 2, "exj": "私は図書館で勉強します。"}, {"id": 245, "w": "library", "k": "ライブラリー", "p": "名詞", "m": ["図書館"], "ex": "I study at the library.", "level": 2, "exj": "彼は病院へ行きました。"}, {"id": 246, "w": "hospital", "k": "ホスピタル", "p": "名詞", "m": ["病院"], "ex": "He went to the hospital.", "level": 2, "exj": "駅でお会いしましょう。"}, {"id": 247, "w": "station", "k": "ステーション", "p": "名詞", "m": ["えき", "駅"], "ex": "I'll meet you at the station.", "level": 2, "exj": "友達を迎えに空港へ行きました。"}, {"id": 248, "w": "airport", "k": "エアポート", "p": "名詞", "m": ["くうこう", "空港"], "ex": "I went to the airport to pick up my friend.", "level": 2, "exj": "私たちはすてきなホテルに泊まりました。"}, {"id": 249, "w": "hotel", "k": "ホテル", "p": "名詞", "m": ["ホテル"], "ex": "We stayed at a nice hotel.", "level": 2, "exj": "明日、博物館を訪れましょう。"}, {"id": 250, "w": "museum", "k": "ミュージアム", "p": "名詞", "m": ["はくぶつかん", "博物館"], "ex": "Let's visit the museum tomorrow.", "level": 2, "exj": "レストランで食べましょう。"}, {"id": 251, "w": "restaurant", "k": "レストラン", "p": "名詞", "m": ["レストラン"], "ex": "Let's eat at the restaurant.", "level": 2, "exj": "お母さんと一緒にスーパーへ行きます。"}, {"id": 252, "w": "supermarket", "k": "スーパーマーケット", "p": "名詞", "m": ["スーパーマーケット"], "ex": "I go to the supermarket with my mom.", "level": 2, "exj": "この近くにコンビニがあります。"}, {"id": 253, "w": "store", "k": "ストア", "p": "名詞", "m": ["お店", "商店"], "ex": "There is a convenience store near here.", "level": 2, "exj": "郵便局で荷物を送りました。"}, {"id": 254, "w": "post office", "k": "ポストオフィス", "p": "名詞", "m": ["郵便局"], "ex": "I sent a package at the post office.", "level": 2, "exj": "お母さんは銀行へ行きました。"}, {"id": 255, "w": "bank", "k": "バンク", "p": "名詞", "m": ["銀行"], "ex": "My mother went to the bank.", "level": 2, "exj": "トイレは2階にあります。"}, {"id": 256, "w": "bathroom", "k": "バスルーム", "p": "名詞", "m": ["お風呂", "トイレ"], "ex": "The bathroom is on the second floor.", "level": 2, "exj": "私の寝室は右側にあります。"}, {"id": 257, "w": "bedroom", "k": "ベッドルーム", "p": "名詞", "m": ["しんしつ", "寝室"], "ex": "My bedroom is on the right.", "level": 2, "exj": "私たちはリビングでテレビを見ます。"}, {"id": 258, "w": "living room", "k": "リビングルーム", "p": "名詞", "m": ["リビング", "居間"], "ex": "We watch TV in the living room.", "level": 2, "exj": "看護師が病気の子どもを助けました。"}, {"id": 259, "w": "nurse", "k": "ナース", "p": "名詞", "m": ["かんごし", "看護師"], "ex": "The nurse helped the sick child.", "level": 1, "exj": "私は中学生です。"}, {"id": 260, "w": "student", "k": "ストゥーデント", "p": "名詞", "m": ["生徒", "学生"], "ex": "I am a junior high school student.", "level": 2, "exj": "英語は私の好きな教科です。"}, {"id": 261, "w": "English", "k": "イングリッシュ", "p": "名詞", "m": ["英語"], "ex": "English is my favorite subject.", "level": 1, "exj": "日本語を話せますか？"}, {"id": 262, "w": "Japanese", "k": "ジャパニーズ", "p": "名詞", "m": ["日本語", "日本人の"], "ex": "Can you speak Japanese?", "level": 1, "exj": "私は算数が好きです。"}, {"id": 263, "w": "math", "k": "マス", "p": "名詞", "m": ["数学"], "ex": "I like math.", "level": 1, "exj": "理科は面白いです。"}, {"id": 264, "w": "science", "k": "サイエンス", "p": "名詞", "m": ["理科", "科学"], "ex": "Science is interesting.", "level": 2, "exj": "月曜日に社会科を勉強します。"}, {"id": 265, "w": "social studies", "k": "ソーシャルスタディーズ", "p": "名詞", "m": ["社会科"], "ex": "I study social studies on Monday.", "level": 2, "exj": "私は歴史を勉強するのが好きです。"}, {"id": 266, "w": "history", "k": "ヒストリー", "p": "名詞", "m": ["れきし", "歴史"], "ex": "I enjoy studying history.", "level": 2, "exj": "美術の授業で陶芸をします。"}, {"id": 267, "w": "art", "k": "アート", "p": "名詞", "m": ["美術", "芸術"], "ex": "We make pottery in art class.", "level": 2, "exj": "体育の授業は楽しいです。"}, {"id": 268, "w": "P.E.", "k": "ピーイー", "p": "名詞", "m": ["体育"], "ex": "P.E. class is fun.", "level": 2, "exj": "明日、算数のテストがあります。"}, {"id": 269, "w": "test", "k": "テスト", "p": "名詞", "m": ["テスト", "試験"], "ex": "I have a math test tomorrow.", "level": 2, "exj": "宿題は終わりましたか？"}, {"id": 270, "w": "homework", "k": "ホームワーク", "p": "名詞", "m": ["宿題"], "ex": "Did you finish your homework?", "level": 2, "exj": "鉛筆を使ってください。"}, {"id": 271, "w": "pencil", "k": "ペンシル", "p": "名詞", "m": ["えんぴつ"], "ex": "Please use a pencil.", "level": 1, "exj": "消しゴムを借りてもいいですか？"}, {"id": 272, "w": "eraser", "k": "イレイザー", "p": "名詞", "m": ["消しゴム"], "ex": "Can I borrow your eraser?", "level": 1, "exj": "直線を引くために定規が必要です。"}, {"id": 273, "w": "ruler", "k": "ルーラー", "p": "名詞", "m": ["ものさし"], "ex": "I need a ruler to draw a straight line.", "level": 2, "exj": "ノートに書いてください。"}, {"id": 274, "w": "notebook", "k": "ノートブック", "p": "名詞", "m": ["ノート"], "ex": "Write it in your notebook.", "level": 2, "exj": "教科書の20ページを開いてください。"}, {"id": 275, "w": "textbook", "k": "テキストブック", "p": "名詞", "m": ["教科書"], "ex": "Open your textbook to page 20.", "level": 2, "exj": "私は放課後にサッカーをします。"}, {"id": 276, "w": "soccer", "k": "サッカー", "p": "名詞", "m": ["サッカー"], "ex": "I play soccer after school.", "level": 1, "exj": "野球は日本で人気があります。"}, {"id": 277, "w": "baseball", "k": "ベースボール", "p": "名詞", "m": ["野球"], "ex": "Baseball is popular in Japan.", "level": 1, "exj": "体育館でバスケットボールをします。"}, {"id": 278, "w": "basketball", "k": "バスケットボール", "p": "名詞", "m": ["バスケットボール"], "ex": "I play basketball in the gym.", "level": 1, "exj": "私の姉はバレーボールをします。"}, {"id": 279, "w": "volleyball", "k": "バレーボール", "p": "名詞", "m": ["バレーボール"], "ex": "My sister plays volleyball.", "level": 2, "exj": "私はテニスのレッスンを受けています。"}, {"id": 280, "w": "tennis", "k": "テニス", "p": "名詞", "m": ["テニス"], "ex": "I take tennis lessons.", "level": 2, "exj": "私は勉強のためにコンピューターを使います。"}, {"id": 281, "w": "computer", "k": "コンピューター", "p": "名詞", "m": ["コンピューター"], "ex": "I use a computer to study.", "level": 2, "exj": "私はインターネットで調べ物をします。"}, {"id": 282, "w": "internet", "k": "インターネット", "p": "名詞", "m": ["インターネット"], "ex": "I look things up on the internet.", "level": 2, "exj": "新しいスマートフォンをもらいました。"}, {"id": 283, "w": "phone", "k": "フォン", "p": "名詞", "m": ["でんわ", "電話"], "ex": "I got a new phone.", "level": 2, "exj": "私は夕食の後でテレビを見ます。"}, {"id": 284, "w": "TV", "k": "ティービー", "p": "名詞", "m": ["テレビ"], "ex": "I watch TV after dinner.", "level": 2, "exj": "祖父はラジオを聴きます。"}, {"id": 285, "w": "radio", "k": "ラジオ", "p": "名詞", "m": ["ラジオ"], "ex": "My grandfather listens to the radio.", "level": 3, "exj": "私はランチにサラダを食べました。"}, {"id": 286, "w": "salad", "k": "サラダ", "p": "名詞", "m": ["サラダ"], "ex": "I had a vegetable salad for lunch.", "level": 2, "exj": "私はハムサンドイッチを作りました。"}, {"id": 287, "w": "sandwich", "k": "サンドイッチ", "p": "名詞", "m": ["サンドイッチ"], "ex": "I made a ham sandwich.", "level": 3, "exj": "今夜はピザを注文しましょう。"}, {"id": 288, "w": "pizza", "k": "ピザ", "p": "名詞", "m": ["ピザ"], "ex": "Let's order pizza tonight.", "level": 3, "exj": "私はランチにハンバーガーを食べました。"}, {"id": 289, "w": "hamburger", "k": "ハンバーガー", "p": "名詞", "m": ["ハンバーガー"], "ex": "I ate a hamburger for lunch.", "level": 3, "exj": "私はチョコレートアイスクリームが大好きです。"}, {"id": 290, "w": "chocolate", "k": "チョコレート", "p": "名詞", "m": ["チョコレート"], "ex": "I love chocolate ice cream.", "level": 3, "exj": "友達とコンサートに行きました。"}, {"id": 291, "w": "concert", "k": "コンサート", "p": "名詞", "m": ["コンサート", "演奏会"], "ex": "I went to a concert with my friend.", "level": 3, "exj": "夏祭りはとても楽しかったです。"}, {"id": 292, "w": "festival", "k": "フェスティバル", "p": "名詞", "m": ["まつり", "フェスティバル"], "ex": "The summer festival was exciting.", "level": 3, "exj": "公園でピクニックをしましょう。"}, {"id": 293, "w": "picnic", "k": "ピクニック", "p": "名詞", "m": ["ピクニック"], "ex": "Let's have a picnic in the park.", "level": 3, "exj": "おばさんからプレゼントをもらいました。"}, {"id": 294, "w": "present", "k": "プレゼント", "p": "名詞", "m": ["プレゼント", "贈り物"], "ex": "I got a present from my aunt.", "level": 3, "exj": "私たちは彼女のためにサプライズを計画しました。"}, {"id": 295, "w": "surprise", "k": "サープライズ", "p": "名詞", "m": ["おどろき", "サプライズ"], "ex": "We planned a surprise for her.", "level": 3, "exj": "私は週末にボランティア活動をします。"}, {"id": 296, "w": "volunteer", "k": "ボランティア", "p": "名詞", "m": ["ボランティア"], "ex": "I do volunteer work on weekends.", "level": 3, "exj": "私は環境についてのポスターを作りました。"}, {"id": 297, "w": "poster", "k": "ポスター", "p": "名詞", "m": ["ポスター"], "ex": "I made a poster about the environment.", "level": 3, "exj": "私たちは学校で制服を着ます。"}, {"id": 298, "w": "uniform", "k": "ユニフォーム", "p": "名詞", "m": ["制服", "ユニフォーム"], "ex": "We wear a uniform at school.", "level": 3, "exj": "私はランドセルに本を入れて運びます。"}, {"id": 299, "w": "backpack", "k": "バックパック", "p": "名詞", "m": ["リュックサック"], "ex": "I carry my books in a backpack.", "level": 3, "exj": "傘を忘れないでください！"}, {"id": 300, "w": "umbrella", "k": "アンブレラ", "p": "名詞", "m": ["かさ"], "ex": "Don't forget your umbrella!", "level": 3, "exj": "みんな一緒にこれをやりましょう。"}], "phrases": []}